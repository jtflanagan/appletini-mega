    ("UHI_A10", "SOM_V13", "SDRAM1_A10"),
    ("UHI_A11", "SOM_Y22", "SDRAM1_A11"),
    ("UHI_A12", "SOM_Y21", "SDRAM1_A12"),
    ("UHI_BA0", "SOM_V20", "SDRAM1_BA0"),
    ("UHI_BA1", "SOM_AB22", "SDRAM1_BA1"),
    ("UHI_N_CS", "SOM_U20", "SDRAM1_NCS"),
    ("UHI_N_RAS", "SOM_AB21", "SDRAM1_NRAS"),
    ("UHI_N_CAS", "SOM_AB20", "SDRAM1_NCAS"),
    ("UHI_N_WE", "SOM_AA19", "SDRAM1_NWE"),
    ("UHI_CLK", "SOM_W20", "SDRAM1_CLK"),
    ("UHI_CKE", "SOM_W19", "SDRAM1_CKE"),
    ("UHI_LDQM", "SOM_AB18", "SDRAM1_LDQM"),
    ("UHI_UDQM", "SOM_AA18", "SDRAM1_UDQM"),
]
_snets = {nn: Net(nn) for (_sp, _sb, nn) in _SDRAM_MAP}
_sdram_kw = {sp: _snets[nn] for (sp, _sb, nn) in _SDRAM_MAP}

# _som_kw accumulates every SOM ball-port connection across subsystems (one big ball pool;
# bank/connector are not routing constraints -- see CLAUDE.md). SDRAM first:
_som_kw = {sb: _snets[nn] for (_sp, sb, nn) in _SDRAM_MAP}

# ============================================================================
# HSPI wiring: CH569 (HSPI slave) <-> FPGA (HSPI master). (ch569_pin, som_ball, net) triples.
# Map = authoritative CH569 pin-mux (CH569WSCH) -> balls picked from the pool near CH569 (left).
# HD0-31 are a byte-lane-swappable bus; the two clocks are flagged for clock-capable balls.
# CLOCKS on clock-capable (GCLK) balls, from the Gowin PBGA484A.json "CFG" field: HRCLK (FPGA's
# source-sync RX capture clock) -> SOM_K18 = 60K GCLKT_6; HTCLK (forwarded TX clock) -> SOM_J20 =
# 60K GCLKT_5 (both BANK5, in the HSPI field). The displaced data bits HD16/HD20 took R18/T18.
# ============================================================================
_HSPI_MAP = [
    ("PA5", "SOM_L14", "HSPI_HD0"),
    ("PA4", "SOM_L15", "HSPI_HD1"),
    ("PA22", "SOM_N20", "HSPI_HD2"),
    ("PA3", "SOM_M20", "HSPI_HD3"),
    ("PA2", "SOM_N22", "HSPI_HD4"),
    ("PA1", "SOM_M22", "HSPI_HD5"),
    ("PA0", "SOM_M21", "HSPI_HD6"),
    ("PB21", "SOM_L21", "HSPI_HD7"),
    ("PB20", "SOM_N18", "HSPI_HD8"),
    ("PB19", "SOM_L19", "HSPI_HD9"),
    ("PB18", "SOM_N19", "HSPI_HD10"),
    ("PB17", "SOM_L20", "HSPI_HD11"),
    ("PA17", "SOM_M18", "HSPI_HD12"),
    ("PB16", "SOM_K21", "HSPI_HD13"),
    ("PB15", "SOM_L18", "HSPI_HD14"),
    ("PB14", "SOM_K22", "HSPI_HD15"),
    ("PB0", "SOM_R18", "HSPI_HD16"),
    ("PB1", "SOM_J22", "HSPI_HD17"),
    ("PB2", "SOM_K19", "HSPI_HD18"),
    ("PA20", "SOM_H22", "HSPI_HD19"),
    ("PB3", "SOM_T18", "HSPI_HD20"),
    ("PB4", "SOM_J21", "HSPI_HD21"),
    ("PB5", "SOM_J19", "HSPI_HD22"),
    ("PB6", "SOM_H19", "HSPI_HD23"),
    ("PA16", "SOM_H20", "HSPI_HD24"),
    ("PB7", "SOM_G20", "HSPI_HD25"),
    ("PB8", "SOM_L16", "HSPI_HD26"),
    ("PB9", "SOM_K16", "HSPI_HD27"),
    ("PB10", "SOM_H17", "HSPI_HD28"),
    ("PB11", "SOM_H18", "HSPI_HD29"),
    ("PB12", "SOM_G17", "HSPI_HD30"),
    ("PB13", "SOM_G18", "HSPI_HD31"),
    ("PA11", "SOM_J20", "HSPI_HTCLK"),
    ("PA19", "SOM_K18", "HSPI_HRCLK"),
    ("PA9", "SOM_R17", "HSPI_HTREQ"),
    ("PA10", "SOM_P16", "HSPI_HTACK"),
    ("PA21", "SOM_U22", "HSPI_HTVLD"),
    ("PA23", "SOM_U21", "HSPI_HTRDY"),
    ("PA18", "SOM_T21", "HSPI_HRACK"),
    ("PA6", "SOM_T20", "HSPI_HRVLD"),
]
_hnets = {nn: Net(nn) for (_p, _b, nn) in _HSPI_MAP}
_som_kw.update({b: _hnets[nn] for (_p, b, nn) in _HSPI_MAP})
_hspi_ch_kw = {"CH_" + p: _hnets[nn] for (p, _b, nn) in _HSPI_MAP}

# ============================================================================
# Apple-bus wiring: cpu_socket FPGA-facing ports (A-side of the LXC shifters + control)
# <-> SOM balls. 1-2.8 MHz, the MOST forgiving bus -> any 3.3V ball, routes freely (inner
# layer). Net name == port name. (cpu_socket_port, som_ball, net):
# ============================================================================
_APPLE_MAP = [
    ("F_A0", "SOM_Y19", "F_A0"),
    ("F_A1", "SOM_Y18", "F_A1"),
    ("F_A2", "SOM_W17", "F_A2"),
    ("F_A3", "SOM_V17", "F_A3"),
    ("F_A4", "SOM_U18", "F_A4"),
    ("F_A5", "SOM_U17", "F_A5"),
    ("F_A6", "SOM_AB15", "F_A6"),
    ("F_A7", "SOM_W14", "F_A7"),
    ("F_A8", "SOM_V14", "F_A8"),
    ("F_A9", "SOM_AA14", "F_A9"),
    ("F_A10", "SOM_M17", "F_A10"),
    ("F_A11", "SOM_M16", "F_A11"),
    ("F_A12", "SOM_M15", "F_A12"),
    ("F_A13", "SOM_M13", "F_A13"),
    ("F_A14", "SOM_L13", "F_A14"),
    ("F_A15", "SOM_U9", "F_A15"),
    ("F_D0", "SOM_U10", "F_D0"),
    ("F_D1", "SOM_U11", "F_D1"),
    ("F_D2", "SOM_U8", "F_D2"),
    ("F_D3", "SOM_K14", "F_D3"),
    ("F_D4", "SOM_K13", "F_D4"),
    ("F_D5", "SOM_T16", "F_D5"),
    ("F_D6", "SOM_H14", "F_D6"),
    ("F_D7", "SOM_J14", "F_D7"),
    ("F_RW", "SOM_G16", "F_RW"),
    ("F_SYNC_VPA", "SOM_G15", "F_SYNC_VPA"),
    ("F_PHI2O_VDA", "SOM_G13", "F_PHI2O_VDA"),
    ("F_MLB", "SOM_H13", "F_MLB"),
    ("F_E", "SOM_J16", "F_E"),
    ("F_VPB", "SOM_J17", "F_VPB"),
    ("F_PHI2", "SOM_K17", "F_PHI2"),
    ("F_RES", "SOM_G21", "F_RES"),
    ("F_IRQ", "SOM_G22", "F_IRQ"),
    ("F_NMI", "SOM_F19", "F_NMI"),
    ("F_RDY", "SOM_F18", "F_RDY"),
    ("F_BE", "SOM_F20", "F_BE"),
    ("F_P3", "SOM_E18", "F_P3"),
    ("F_P38", "SOM_F21", "F_P38"),
    ("CPU_OE_N", "SOM_C22", "CPU_OE_N"),
    ("CPU_DATA_DIR", "SOM_E22", "CPU_DATA_DIR"),
    ("CPU_P3_DIR", "SOM_B22", "CPU_P3_DIR"),
    ("CPU_P38_DIR", "SOM_D22", "CPU_P38_DIR"),
    ("F_RES_REL", "SOM_E21", "F_RES_REL"),
    ("CPU_5V_ABSENT", "SOM_D21", "CPU_5V_ABSENT"),
]
_anets = {nn: Net(nn) for (_p, _b, nn) in _APPLE_MAP}
_som_kw.update({b: _anets[nn] for (_p, b, nn) in _APPLE_MAP})
_cpu_kw = {p: _anets[nn] for (p, _b, nn) in _APPLE_MAP}

# ============================================================================
# JTAG (FT2232 ch.A -> SOM BANK12 config balls) + UART console (ch.B) + config-status readback.
# DONE/READY are the SOM's own role-named config pins (BTB9900); FT2232 ACBUS0/1 poll them.
# (ft_port, som_ball_port, net):
# ============================================================================
_JTU_MAP = [
    ("FT_JTAG_TCK", "SOM_T13", "FT_JTAG_TCK"),
    ("FT_JTAG_TMS", "SOM_U13", "FT_JTAG_TMS"),
    ("FT_JTAG_TDI", "SOM_V12", "FT_JTAG_TDI"),
    ("FT_JTAG_TDO", "SOM_R13", "FT_JTAG_TDO"),
    ("FT_UART_TX", "SOM_R19", "FT_UART_TX"),
    ("FT_UART_RX", "SOM_P19", "FT_UART_RX"),
    ("FT_CFG_DONE", "SOM_DONE", "CFG_DONE"),
    ("FT_CFG_READY", "SOM_READY", "CFG_READY"),
]
_jnets = {nn: Net(nn) for (_p, _b, nn) in _JTU_MAP}
_som_kw.update({b: _jnets[nn] for (_p, b, nn) in _JTU_MAP})
_prog_kw = {p: _jnets[nn] for (p, _b, nn) in _JTU_MAP}

# ============================================================================
# Instantiate subsystems with rails wired. Signals wired: SDRAM + HSPI. Apple/JTAG next.
# ============================================================================
PowerMod(name="PWR", GND=GND, P5V=P5V, P3V3=P3V3)

SomBtb(
    name="SOM",
    GND=GND,
    P5V=P5V,
    VCCIO_1_2=P3V3,
    VCCIO_4_5=P3V3,
    VCCIO_6_7_8=P3V3,  # SDRAM banks (3.3V)
    # VCCIO_138B5 left unconnected -- voltage TBD, no pilot signal uses it (see som_btb.zen)
    **_som_kw,
)

Sdram(name="SDRAM", GND=GND, VDD=P3V3, **_sdram_kw)

Programming(name="PROG", GND=GND, P3V3=P3V3, **_prog_kw)
Usb3Bridge(name="USB3", GND=GND, P3V3=P3V3, **_hspi_ch_kw)
CpuSocket(name="CPU", GND=GND, P3V3=P3V3, **_cpu_kw)
Mechanical(name="MECH")
