"""
appletini-mega — Apple II/IIgs accelerator carrier for a Sipeed Tang Mega 60K SOM.

Top-level board. WIRING (2026-07-09): all subsystems joined; every functional bus mapped to
the SOM balls. Done here, in order:
  * RAILS: one shared GND + P5V + P3V3, owned here and passed into every module's rail io()
    ports (the modules used to each declare private GND/P3V3 nets that never joined).
  * SDRAM (fetch path): SDRAM0 (U_LO, DQ[15:0]) -> C2399, SDRAM1 (U_HI, DQ[31:16]) -> C2400.
  * HSPI: CH569 (slave) <-> FPGA (master), 32 data + 2 clocks + 6 handshake, near CH569.
  * Apple bus: cpu_socket A-side (16A + 8D + status/flip + control) <-> SOM.
  * JTAG/UART: FT2232 ch.A -> SOM BANK12 config balls; ch.B UART console.

BALL POOL MODEL (per the SOM cross-die contract, CLAUDE.md): the SOM I/O balls are ONE pool
-- bank number and connector are NOT routing constraints. The only ball-choice rules are:
skip the 1.5V balls (60K BANK9), keep clock-capable (GCLK) pins for signals that need them (the
HSPI RX/TX clocks ARE placed on GCLK balls -- see the HSPI map), and prefer escape convenience. So every
signal-to-ball assignment here is a *starting* map (deterministic, disjoint, verified); the
exact ball for each bit is re-optimised for clean escape at place-and-route -- what is fixed
is the connectivity (which chip pin reaches a SOM ball, on which rails).

Subsystems:
  - som_btb      Tang Mega 60K SOM board-to-board (DF40) connectors + all labeled pins
  - power        12 V barrel -> buck 5 V (VBUS_SOM) -> 3.3 V (VCCIO / logic / IC rails)
  - sdram        2x AS4C16M16SA 16-bit SDR, wired as one 32-bit-wide bus (fetch path)
  - programming  FT2232H (ch.A = JTAG/MPSSE, ch.B = UART console) + 12 MHz xtal + USB-C
  - usb3         WCH CH569 HSPI<->USB3 SuperSpeed bridge + 30 MHz xtal + USB3 connector
  - cpu_socket   6502/65816 CPU-socket bus interface (LXC level shifters + deadman reset)
"""

SomBtb = Module("modules/som_btb.zen")
PowerMod = Module("modules/power.zen")  # not 'Power' -- that's the builtin net constructor
Sdram = Module("modules/sdram.zen")
Programming = Module("modules/programming.zen")
Usb3Bridge = Module("modules/usb3.zen")
CpuSocket = Module("modules/cpu_socket.zen")
Mechanical = Module("modules/mechanical.zen")

Board(
    name="appletini-mega",
    layout_path="layout",
    layers=6,  # dense 0.4mm DF40 escape (3 conns) + two 32-bit buses + USB3 SS; 4 layers too tight
)

# ============================================================================
# Shared board rails (owned here; power SOURCES them, everyone else CONSUMES them).
# All VCCIO banks in use are the 3.3 V grouping (legal on both dies -- see CLAUDE.md).
# ============================================================================
GND = Ground()
P5V = Power("P5V")  # VBUS_SOM 5V (buck output) -> SOM P5V pins
P3V3 = Power("P3V3")  # 3.3V (LDO output) -> logic + VCCIO + IC rails

# ============================================================================
# SDRAM pilot wiring: (sdram_port, som_ball, functional_net) triples.
# One Net per functional name, passed to BOTH the SDRAM device port and the SOM ball port
# so the two module-local nodes become the SAME physical net.
# ============================================================================
_SDRAM_MAP = [
    ("ULO_DQ0", "SOM_E17", "SDRAM_DQ0"),
    ("ULO_DQ1", "SOM_B18", "SDRAM_DQ1"),
    ("ULO_DQ2", "SOM_F16", "SDRAM_DQ2"),
    ("ULO_DQ3", "SOM_B17", "SDRAM_DQ3"),
    ("ULO_DQ4", "SOM_D16", "SDRAM_DQ4"),
    ("ULO_DQ5", "SOM_C17", "SDRAM_DQ5"),
    ("ULO_DQ6", "SOM_E16", "SDRAM_DQ6"),
    ("ULO_DQ7", "SOM_D17", "SDRAM_DQ7"),
    ("ULO_DQ8", "SOM_D15", "SDRAM_DQ8"),
    ("ULO_DQ9", "SOM_A16", "SDRAM_DQ9"),
    ("ULO_DQ10", "SOM_D14", "SDRAM_DQ10"),
    ("ULO_DQ11", "SOM_A15", "SDRAM_DQ11"),
    ("ULO_DQ12", "SOM_F15", "SDRAM_DQ12"),
    ("ULO_DQ13", "SOM_B16", "SDRAM_DQ13"),
    ("ULO_DQ14", "SOM_F14", "SDRAM_DQ14"),
    ("ULO_DQ15", "SOM_B15", "SDRAM_DQ15"),
    ("ULO_A0", "SOM_F13", "SDRAM0_A0"),
    ("ULO_A1", "SOM_A14", "SDRAM0_A1"),
    ("ULO_A2", "SOM_A13", "SDRAM0_A2"),
    ("ULO_A3", "SOM_B13", "SDRAM0_A3"),
    ("ULO_A4", "SOM_C13", "SDRAM0_A4"),
    ("ULO_A5", "SOM_C15", "SDRAM0_A5"),
    ("ULO_A6", "SOM_C14", "SDRAM0_A6"),
    ("ULO_A7", "SOM_E14", "SDRAM0_A7"),
    ("ULO_A8", "SOM_E13", "SDRAM0_A8"),
    ("ULO_A9", "SOM_C20", "SDRAM0_A9"),
    ("ULO_A10", "SOM_A21", "SDRAM0_A10"),
    ("ULO_A11", "SOM_D20", "SDRAM0_A11"),
    ("ULO_A12", "SOM_B21", "SDRAM0_A12"),
    ("ULO_BA0", "SOM_D19", "SDRAM0_BA0"),
    ("ULO_BA1", "SOM_A20", "SDRAM0_BA1"),
    ("ULO_N_CS", "SOM_E19", "SDRAM0_NCS"),
    ("ULO_N_RAS", "SOM_B20", "SDRAM0_NRAS"),
    ("ULO_N_CAS", "SOM_C19", "SDRAM0_NCAS"),
    ("ULO_N_WE", "SOM_A19", "SDRAM0_NWE"),
    ("ULO_CLK", "SOM_C18", "SDRAM0_CLK"),
    ("ULO_CKE", "SOM_A18", "SDRAM0_CKE"),
    ("ULO_LDQM", "SOM_H15", "SDRAM0_LDQM"),
    ("ULO_UDQM", "SOM_J15", "SDRAM0_UDQM"),
    ("UHI_DQ0", "SOM_P17", "SDRAM_DQ16"),
    ("UHI_DQ1", "SOM_N17", "SDRAM_DQ17"),
    ("UHI_DQ2", "SOM_N15", "SDRAM_DQ18"),
    ("UHI_DQ3", "SOM_N13", "SDRAM_DQ19"),
    ("UHI_DQ4", "SOM_N14", "SDRAM_DQ20"),
    ("UHI_DQ5", "SOM_U16", "SDRAM_DQ21"),
    ("UHI_DQ6", "SOM_T15", "SDRAM_DQ22"),
    ("UHI_DQ7", "SOM_V15", "SDRAM_DQ23"),
    ("UHI_DQ8", "SOM_R16", "SDRAM_DQ24"),
    ("UHI_DQ9", "SOM_U15", "SDRAM_DQ25"),
    ("UHI_DQ10", "SOM_P15", "SDRAM_DQ26"),
    ("UHI_DQ11", "SOM_R14", "SDRAM_DQ27"),
    ("UHI_DQ12", "SOM_P14", "SDRAM_DQ28"),
    ("UHI_DQ13", "SOM_T14", "SDRAM_DQ29"),
    ("UHI_DQ14", "SOM_W22", "SDRAM_DQ30"),
    ("UHI_DQ15", "SOM_W21", "SDRAM_DQ31"),
    ("UHI_A0", "SOM_AA21", "SDRAM1_A0"),
    ("UHI_A1", "SOM_AA20", "SDRAM1_A1"),
    ("UHI_A2", "SOM_Y17", "SDRAM1_A2"),
    ("UHI_A3", "SOM_AB17", "SDRAM1_A3"),
    ("UHI_A4", "SOM_AA16", "SDRAM1_A4"),
    ("UHI_A5", "SOM_AB16", "SDRAM1_A5"),
    ("UHI_A6", "SOM_AA15", "SDRAM1_A6"),
    ("UHI_A7", "SOM_W16", "SDRAM1_A7"),
