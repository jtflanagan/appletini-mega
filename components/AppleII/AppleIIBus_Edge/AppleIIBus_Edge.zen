p47 = io(Net, optional=True)
p48 = io(Net, optional=True)
p49 = io(Net, optional=True)
p50 = io(Net, optional=True)

Component(
    name="AppleIIBus_Edge",
    symbol=Symbol(library="AppleIIBus_Edge.kicad_sym"),
    pins={
        "~{IOSEL}": p1,
        "A0": p2,
        "A1": p3,
        "A2": p4,
        "A3": p5,
        "A4": p6,
        "A5": p7,
        "A6": p8,
        "A7": p9,
        "A8": p10,
        "A9": p11,
        "A10": p12,
        "A11": p13,
        "A12": p14,
        "A13": p15,
        "A14": p16,
        "A15": p17,
        "R/~{W}": p18,
        "SYNC": p19,
        "~{IOSTRB}": p20,
        "~{RDY}": p21,
        "~{DMA}": p22,
        "~{INTOUT}": p23,
        "~{DMAOUT}": p24,
        "+5V": p25,
        "GND": p26,
        "~{DMAIN}": p27,
        "~{INTIN}": p28,
        "~{NMI}": p29,
        "~{IRQ}": p30,
